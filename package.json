{
  "name": "pts-plan",
  "displayName": "Pixel Plan Injection",
  "version": "2.9.2",
  "description": "Бесплатное расширение, которое превращает стандартный Bitrix24 в удобный рабочий инструмент.",
  "keywords": [
    "chrome-extension",
    "vue",
    "vite",
    "create-chrome-ext"
  ],
  "license": "MIT",
  "author": "MelentQ",
  "type": "module",
  "scripts": {
    "build": "npm run build-css && vite build",
    "build-css": "npx @tailwindcss/cli -i src/css/content-styles.css -o public/assets/content-styles.css --minify && npm run copy-assets",
    "copy-assets": "cp -r node_modules/primeicons/fonts/ public/assets/",
    "dev": "npm run build-css && vite",
    "preview": "npm run build-css && vite preview"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "axios": "^1.16.1",
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.21",
    "jsonrepair": "^3.14.0",
    "jszip": "^3.10.1",
    "lodash-es": "^4.18.1",
    "marked": "^18.0.4",
    "primeicons": "^7.0.0",
    "primelocale": "^2.3.2",
    "primevue": "^4.5.5",
    "vue": "^3.5.24",
    "vue-color": "^3.3.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "chrome-types": "^0.1.429",
    "eslint": "^10.4.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "tailwindcss": "^4.1.17",
    "tailwindcss-primeui": "^0.6.1",
    "vite": "^7.3.3"
  },
  "engines": {
    "node": ">=20.19.6"
  }
}
